# ============================================================
# Entropy AI Operations — .gitignore
# Next.js + Node.js + TypeScript + Prisma
# ============================================================

# ----- Dependencies -----
node_modules/
.npm

# ----- Next.js Build Output -----
.next/
out/
build/
dist/

# ----- Environment Variables -----
# NEVER commit real credentials
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# .env.example is committed intentionally — it has no real values

# ----- Prisma -----
# Prisma generates this at runtime — do not commit
prisma/generated/

# ----- TypeScript -----
*.tsbuildinfo
next-env.d.ts

# ----- Testing -----
coverage/
.nyc_output/

# ----- OS Files -----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ----- IDE / Editor -----
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# ----- Logs -----
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ----- Package Manager Lock Files (keep npm only) -----
yarn.lock
pnpm-lock.yaml
bun.lockb

# ----- Misc -----
.vercel
.turbo
*.tgz
