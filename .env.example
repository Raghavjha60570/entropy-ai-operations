# ============================================================
# Entropy AI Operations — Environment Variables
# ============================================================
# Copy this file to .env.local for local development:
#   cp .env.example .env.local
#
# NEVER commit .env.local or any file containing real secrets.
# ============================================================

# --- Database ---
# PostgreSQL connection string (managed by Prisma)
DATABASE_URL=

# --- Authentication ---
# Secret used to sign and verify authentication tokens.
# Generate a strong random value: openssl rand -base64 32
AUTH_SECRET=

# --- AI / OpenAI ---
# OpenAI API key for LLM-powered features
OPENAI_API_KEY=
